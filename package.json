{
  "name": "shadcn-schema",
  "type": "module",
  "version": "0.4.0",
  "packageManager": "pnpm@11.1.3",
  "description": "Reusable schema for the Shadcn registry",
  "author": "ocavue <ocavue@gmail.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/ocavue",
  "homepage": "https://github.com/ocavue/shadcn-schema#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ocavue/shadcn-schema.git"
  },
  "bugs": "https://github.com/ocavue/shadcn-schema/issues",
  "keywords": [],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "fix": "eslint --fix . && prettier --write .",
    "test": "vitest",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ocavue/eslint-config": "^4.5.8",
    "@ocavue/tsconfig": "^0.7.1",
    "@types/node": "^20.19.10",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.7"
  }
}
